// =======================
// DATABASE
// =======================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// =======================
// PATIENT
// =======================

model Patient {
  id              String   @id @default(uuid())

  name            String
  age             Int?
  phone           String   
  address         String?
  gender          String

  guardian        String?
  occupation      String?
  medicalHistory  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())

  // Relations
  appointments    Appointment[]
  visits          Visit[]

  @@index([phone])
}

// =======================
// APPOINTMENT
// =======================

model Appointment {
  id            String   @id @default(uuid())

  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])

  status        AppointmentStatus @default(SCHEDULED)

  doctorName    String?

  date          DateTime
  time          String

  reason        String?
  notes         String?

  // reminderSent  Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  @@index([date])
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// =======================
// VISIT
// =======================

model Visit {
  id             String   @id @default(uuid())

  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])

  doctorName     String?

  date           DateTime
  time           String

  reason         String?

  diagnosis      String?
  prescription   String?
  notes          String?

  // =======================
  // BILLING SUMMARY
  // =======================

  totalAmount    Float @default(0)
  paidAmount     Float @default(0)
  dueAmount      Float @default(0)

  paymentStatus  PaymentStatus @default(UNPAID)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())

  // Relations
  payments       Payment[]

  @@index([date])
  @@index([patientId])
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

// =======================
// PAYMENT
// =======================

model Payment {
  id            String   @id @default(uuid())

  visitId       String
  visit         Visit    @relation(fields: [visitId], references: [id])

  amount        Float

  method        PaymentMethod

  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([visitId])
}

enum PaymentMethod {
  CASH
  BANK
  ONLINE
}